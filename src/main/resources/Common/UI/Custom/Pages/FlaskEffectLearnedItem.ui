$C = "../Common.ui";

Group {
  Padding: (Bottom: 5);
  LayoutMode: Top;

  Group #Item {
    LayoutMode: Left;
    Padding: (Full: 5);
    Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

    AssetImage #ItemIcon {
      AssetPath: "UI/Custom/Common/ContainerPanelPatch.png";
      Padding: (Full: 5);
      Anchor: (Width: 34, Height: 34);
    }

    Label #ItemLabel {
      FlexWeight: 1;
      Text: %server.hyflask.ui.effectSelection.item.unknown;
      TooltipText: %server.hyflask.ui.effectSelection.item.unknown;
      TextTooltipShowDelay: 1;
      TextTooltipStyle: $C.@DefaultTextTooltipStyle;
      Style: (VerticalAlignment: Center);
      Padding: (Left: 10, Right: 5);
    }

    Group {
      LayoutMode: Left;
      Padding: (Right: 10);

      Label #ItemCostRange {
        Text: "0";
        Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center);
        Padding: (Right: 5);
      }

      Group {
        AssetImage {
          AssetPath: "UI/Custom/Common/SliderHandle.png";
          Anchor: (Width: 10, Height: 10);
        }
      }
    }


    $C.@SecondaryTextButton #AddButton {
      Anchor: (Width: 30);
      Padding: (Full: 2);
      Text: "+";
      TooltipText: %server.hyflask.ui.effectSelection.learnedEffect.item.addEffect.tooltip;
      TextTooltipStyle: $C.@DefaultTextTooltipStyle;
    }

  }
}